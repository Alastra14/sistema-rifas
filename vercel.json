{
  "version": 2,
  "name": "sistema-rifas",
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/rifa",
      "dest": "/rifa_sistema.html"
    },
    {
      "src": "/configurar",
      "dest": "/configurador.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
